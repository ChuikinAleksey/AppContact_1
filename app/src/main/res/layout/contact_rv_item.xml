<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:elevation="5dp"
    android:background="@color/white"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="8dp"> <!-- Скруглил углы, хотя в ТЗ прямоугольник, глазу приятнее-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"> <!-- Отступ не был дан, ставлю на глаз -->

    <ImageView
        android:id="@+id/contactImageView"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/avatar"
        android:layout_gravity="center" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp"> <!-- Расстояние между изображением и текстом тоже не задано -->

    <TextView
        android:id="@+id/nameTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contact Name"
        android:textSize="16sp"
        android:textStyle="bold" /> <!-- Имя по умолчанию -->

    <TextView
        android:id="@+id/phoneTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phone Number"
        android:textSize="14sp" /> <!-- Номер телефона по умолчанию -->

</LinearLayout>

</LinearLayout>
    </androidx.cardview.widget.CardView>